#!/bin/sh

print_msg() { echo "[*] $1"; }
print_error() { echo "[!] Error: $1"; exit 1; }
print_step() { echo "=== $1 ==="; }

# =========================
# Installation mode selection
# =========================
print_step "Select installation mode"

echo "1) Low RAM device (enable ZRAM swap)"
echo "2) High RAM device (no ZRAM)"
echo ""

MODE=""

printf "Enter option (1 or 2) [default:2]: "

if [ -t 0 ]; then
    read -r MODE
else
    read -r MODE < /dev/tty 2>/dev/null
fi

[ -z "$MODE" ] && MODE=2

case "$MODE" in
1|2) ;;
*) MODE=2 ;;
esac

print_msg "Selected mode: $MODE"

# =========================
# Update package list
# =========================
print_step "Updating package list"
opkg update || print_error "Failed to update package list"

# =========================
# Set root password
# =========================
print_step "Setting root password"

if command -v chpasswd >/dev/null 2>&1; then
    echo "root:rootroot" | chpasswd
else
    (echo "rootroot"; sleep 1; echo "rootroot") | passwd root >/dev/null 2>&1
fi

print_msg "Root password set"

# =========================
# Low RAM mode: ZRAM + tuning
# =========================
if [ "$MODE" = "1" ]; then

    print_step "Installing ZRAM packages"
    opkg install kmod-zram zram-swap kmod-lib-zstd || print_error "Failed to install ZRAM packages"

    ZRAM_SIZE=131072  # 128MB fixed

    /etc/init.d/zram stop 2>/dev/null

    uci set system.@system[0].zram_size="$ZRAM_SIZE"
    uci set system.@system[0].zram_comp_algo='zstd'

    uci set system.@system[0].vm_swappiness='180'
    uci set system.@system[0].vm_min_free_kbytes='16384'
    uci set system.@system[0].vm_vfs_cache_pressure='200'

    uci commit system

    /etc/init.d/zram enable
    /etc/init.d/zram start

    print_msg "ZRAM enabled (128MB, zstd)"
    print_msg "Low RAM mode completed"

else
    print_msg "High RAM mode selected (ZRAM skipped)"
fi

# =========================
# TPROXY
# =========================
print_step "Installing kmod-nft-tproxy"
opkg install kmod-nft-tproxy || print_error "Failed to install kmod-nft-tproxy"

# =========================
# Geo databases
# =========================
print_step "Installing Geo databases"
mkdir -p /opt/clash || exit
cd /opt/clash || exit

wget -q -O geosite.dat \
https://github.com/MetaCubeX/meta-rules-dat/releases/latest/download/geosite.dat

wget -q -O geoip.dat \
https://github.com/MetaCubeX/meta-rules-dat/releases/latest/download/geoip.dat

print_msg "Geo databases installed"

# =========================
# LuCI app
# =========================
print_step "Installing luci-app-clash"
wget -q -O /tmp/luci-app-clash.ipk \
https://raw.githubusercontent.com/bobaboba76/lash/main/luci-app-clash.ipk \
|| print_error "Failed to download luci-app-clash"

opkg install /tmp/luci-app-clash.ipk || print_error "Failed to install luci-app-clash"
rm -f /tmp/luci-app-clash.ipk
print_msg "luci-app-clash installed"

# Stop Clash if running
/etc/init.d/clash stop 2>/dev/null
/etc/init.d/clash disable 2>/dev/null

# =========================
# CLASH CORE
# =========================
print_step "Installing Clash core"

mkdir -p /opt/clash/bin || print_error "Failed to create directory"

CLASH_URL="https://raw.githubusercontent.com/bobaboba76/lash/main/clash.gz"

# Скачиваем
wget -q -O /opt/clash/bin/clash.gz "$CLASH_URL" \
  || print_error "Failed to download clash"

# Проверяем целостность gz архива
gzip -t /opt/clash/bin/clash.gz \
  || print_error "clash.gz corrupt (gzip check failed)"

# Распаковываем
gunzip -f /opt/clash/bin/clash.gz \
  || print_error "Failed to extract clash"

# Проверяем размер бинарника после распаковки
CLASH_SIZE=$(wc -c < /opt/clash/bin/clash)
[ "$CLASH_SIZE" -lt 11000000 ] \
  && print_error "clash too small (${CLASH_SIZE} bytes), possibly corrupt"

# Проверяем что это ELF бинарник
ELF_MAGIC=$(dd if=/opt/clash/bin/clash bs=4 count=1 2>/dev/null | hexdump -e '4/1 "%02x"')
[ "$ELF_MAGIC" != "7f454c46" ] \
  && print_error "clash is not a valid ELF binary"

print_msg "Clash binary OK (${CLASH_SIZE} bytes)"

chmod +x /opt/clash/bin/clash

# Запускаем сервис
/etc/init.d/clash enable
/etc/init.d/clash start

print_msg "Clash installed and enabled"

# =========================
# Cron update
# =========================
print_step "Setting cron update"
crontab -l 2>/dev/null | grep -v meta-rules-dat > /tmp/cron

echo "0 2 1 * * wget -q -O /opt/clash/geosite.dat https://github.com/MetaCubeX/meta-rules-dat/releases/latest/download/geosite.dat" >> /tmp/cron
echo "0 2 1 * * wget -q -O /opt/clash/geoip.dat https://github.com/MetaCubeX/meta-rules-dat/releases/latest/download/geoip.dat" >> /tmp/cron
echo "0 3 2 * * sleep 70 && /sbin/reboot" >> /tmp/cron

crontab /tmp/cron
rm -f /tmp/cron
/etc/init.d/cron enable
/etc/init.d/cron restart
print_msg "Cron installed"

# =========================
# Hostname, NTP & DNS
# =========================
print_step "Configuring hostname, NTP and fallback DNS"

uci set system.@system[0].hostname='miwifi'
uci set system.@system[0].timezone='MSK-3'
uci set system.@system[0].zonename='Europe/Moscow'
uci set system.ntp.server='0.openwrt.pool.ntp.org 1.openwrt.pool.ntp.org 162.159.200.123 162.159.200.1 17.253.84.125 17.253.116.125 213.180.204.183'

# DNS fallback (used when Clash is stopped)
uci set dhcp.@dnsmasq[0].noresolv='1'
uci del_list dhcp.@dnsmasq[0].server='77.88.8.8' 2>/dev/null
uci del_list dhcp.@dnsmasq[0].server='83.220.169.155' 2>/dev/null
uci del_list dhcp.@dnsmasq[0].server='9.9.9.9' 2>/dev/null

uci add_list dhcp.@dnsmasq[0].server='77.88.8.8'
uci add_list dhcp.@dnsmasq[0].server='83.220.169.155'
uci add_list dhcp.@dnsmasq[0].server='9.9.9.9'

uci commit system
uci commit dhcp

print_msg "Hostname, NTP and DNS configured"

# =========================
# WIFI STABILITY + CONFIG
# =========================
print_step "Applying WiFi stability tuning"

# Country (Panama for max power/flexibility)
uci set wireless.radio0.country='PA'
uci set wireless.radio1.country='PA'

# SSID
uci set wireless.@wifi-iface[0].ssid='Miwifi'
uci set wireless.@wifi-iface[1].ssid='Miwifi'

# Encryption (WPA2 for compatibility)
uci set wireless.@wifi-iface[0].encryption='psk2'
uci set wireless.@wifi-iface[1].encryption='psk2'

# Password
uci set wireless.@wifi-iface[0].key='rootrootroot'
uci set wireless.@wifi-iface[1].key='rootrootroot'

# Stability tuning
uci set wireless.@wifi-iface[0].wpa_group_rekey='86400'
uci set wireless.@wifi-iface[1].wpa_group_rekey='86400'

uci set wireless.@wifi-iface[0].disassoc_low_ack='0'
uci set wireless.@wifi-iface[1].disassoc_low_ack='0'

uci set wireless.@wifi-iface[0].dtim_period='2'
uci set wireless.@wifi-iface[1].dtim_period='2'

uci set wireless.radio0.beacon_int='100'
uci set wireless.radio1.beacon_int='100'

uci set wireless.@wifi-iface[0].multicast_to_unicast='1'
uci set wireless.@wifi-iface[1].multicast_to_unicast='1'

uci commit wireless

print_msg "WiFi configured: Miwifi / WPA2"

# =========================
# ENABLE WIFI APs (force)
# =========================
print_step "Enabling Wi-Fi access points"
# enable all radios
for dev in $(uci show wireless | grep "=wifi-device" | cut -d. -f2 | cut -d= -f1); do
    uci set wireless.$dev.disabled='0' 2>/dev/null
done

# enable all AP interfaces
for iface in $(uci show wireless | grep "=wifi-iface" | cut -d. -f2 | cut -d= -f1); do
    uci set wireless.$iface.disabled='0' 2>/dev/null
done

uci commit wireless

print_msg "Wi-Fi APs enabled"

# =========================
# Miwifi-Direct bypass AP (UCI only, applied after reboot)
# =========================
print_step "Configuring Miwifi-Direct bypass AP (deferred)"

IFACE='direct_lan'
SSID='Miwifi-Direct'
PASS='rootrootroot'
GW='192.168.11.1'
RADIO='radio0'
BRIDGE='br-direct'

# Network interface
uci -q delete network.$IFACE
uci set network.$IFACE=interface
uci set network.$IFACE.proto='static'
uci set network.$IFACE.ipaddr="$GW"
uci set network.$IFACE.netmask='255.255.255.0'
uci set network.$IFACE.device="$BRIDGE"

uci -q delete network.direct_lan_dev
uci set network.direct_lan_dev=device
uci set network.direct_lan_dev.name="$BRIDGE"
uci set network.direct_lan_dev.type='bridge'
uci commit network

# DHCP
uci -q delete dhcp.$IFACE
uci set dhcp.$IFACE=dhcp
uci set dhcp.$IFACE.interface="$IFACE"
uci set dhcp.$IFACE.start='100'
uci set dhcp.$IFACE.limit='50'
uci set dhcp.$IFACE.leasetime='12h'
uci set dhcp.$IFACE.dhcp_option='6,8.8.8.8,1.1.1.1,77.88.8.8'
uci commit dhcp

# WiFi AP
uci -q delete wireless.direct_wifi
uci set wireless.direct_wifi=wifi-iface
uci set wireless.direct_wifi.device="$RADIO"
uci set wireless.direct_wifi.mode='ap'
uci set wireless.direct_wifi.ssid="$SSID"
uci set wireless.direct_wifi.encryption='psk2'
uci set wireless.direct_wifi.key="$PASS"
uci set wireless.direct_wifi.network="$IFACE"
uci commit wireless

# Firewall zone
OLD=$(uci show firewall | grep "name='direct_zone'" | cut -d. -f2 | cut -d= -f1)
[ -n "$OLD" ] && uci delete firewall.$OLD

uci add firewall zone > /dev/null
ZONE=$(uci show firewall | grep "=zone" | tail -1 | cut -d. -f2 | cut -d= -f1)
uci set firewall.$ZONE.name='direct_zone'
uci set firewall.$ZONE.network="$IFACE"
uci set firewall.$ZONE.input='ACCEPT'
uci set firewall.$ZONE.output='ACCEPT'
uci set firewall.$ZONE.forward='ACCEPT'
uci set firewall.$ZONE.masq='1'
uci set firewall.$ZONE.mtu_fix='1'
uci commit firewall

# Forwarding direct_zone → wan
uci add firewall forwarding > /dev/null
FWD=$(uci show firewall | grep "=forwarding" | tail -1 | cut -d. -f2 | cut -d= -f1)
uci set firewall.$FWD.src='direct_zone'
uci set firewall.$FWD.dest='wan'
uci commit firewall

# nft.conf patch — at this point Clash isn't running yet,
# so patch the file if it already exists, otherwise create a marker
# that post-install can pick up. Usually Clash start above creates it.
NFT_CONF='/opt/clash/nft.conf'
if [ -f "$NFT_CONF" ]; then
    grep -v 'iifname "br-direct" return' "$NFT_CONF" > /tmp/nft_clean.conf
    mv /tmp/nft_clean.conf "$NFT_CONF"
    sed -i 's/ip daddr \$RESERVED_IP return/iifname "br-direct" return\n        ip daddr $RESERVED_IP return/' "$NFT_CONF"
    print_msg "nft.conf patched"
else
    print_msg "nft.conf not found yet — will need manual patch after first Clash start"
fi

print_msg "Miwifi-Direct config written (takes effect after reboot)"

# =========================
# Reboot
# =========================
print_step "Rebooting device"
(sleep 5; reboot) &
