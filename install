#!/bin/sh

print_msg() { echo "[*] $1"; }
print_error() { echo "[!] Error: $1"; exit 1; }
print_step() { echo "=== $1 ==="; }

print_step "Select installation mode"
echo "1) Low RAM device (enable ZRAM swap)"
echo "2) High RAM device (no ZRAM)"
echo ""

MODE=""
if [ -e /dev/tty ]; then
    printf "Enter option (1 or 2) [default:2]: "
    read MODE < /dev/tty
fi
[ -z "$MODE" ] && MODE=2
print_msg "Selected mode: $MODE"

print_step "Updating package list"
opkg update || print_error "Failed to update package list"

if [ "$MODE" = "1" ]; then

print_step "Installing ZRAM"

opkg install kmod-zram zram-swap kmod-lib-zstd coreutils-base64 openssl-util \
|| print_error "Failed to install ZRAM packages"

ZRAM_SIZE=$((128 * 1024))

print_msg "Setting ZRAM size to: $ZRAM_SIZE KB (128 MB fixed)"

uci set system.@system[0].zram_size="$ZRAM_SIZE"
uci commit system

/etc/init.d/zram enable
/etc/init.d/zram start

print_msg "ZRAM enabled"

else

print_msg "High RAM mode (ZRAM skipped)"

fi

print_step "Installing kmod-nft-tproxy"

opkg install kmod-nft-tproxy || print_error "Failed to install kmod-nft-tproxy"

print_step "Installing luci-app-clash"

ENC_LUCI="aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2JvYmFib2JvYTc2L2xhc2gvbWFpbi9sdWNpLWFwcC1jbGFzaC5pcGs="

wget -q -O /tmp/luci-app-clash.ipk $(echo "$ENC_LUCI" | base64 -d) \
|| print_error "Failed to download luci-app-clash"

opkg install /tmp/luci-app-clash.ipk \
|| print_error "Failed to install luci-app-clash"

rm -f /tmp/luci-app-clash.ipk

print_msg "luci-app-clash installed"

print_msg "Stopping auto-started Clash..."

/etc/init.d/clash stop 2>/dev/null
/etc/init.d/clash disable 2>/dev/null

print_step "Installing Clash"

mkdir -p /opt/clash/bin || print_error "Failed to create directory"

ENC_CLASH="aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2JvYmFib2JvYTc2L2xhc2gvbWFpbi9jbGFzaC5nei"

wget -q -O /opt/clash/bin/clash.gz $(echo "$ENC_CLASH" | base64 -d) \
|| print_error "Failed to download clash.gz"

gunzip -f /opt/clash/bin/clash.gz \
|| print_error "Failed to extract clash.gz"

chmod +x /opt/clash/bin/clash

print_msg "Clash installed"

print_step "Installing Geo databases"

ENC_GEOSITE="aHR0cHM6Ly9naXRodWIuY29tL01ldGFDdWJlWC9tZXRhLXJ1bGVzLWRhdC9yZWxlYXNlcy9sYXRlc3QvZG93bmxvYWQvZ2Vvc2l0ZS5kYXQ="
ENC_GEOIP="aHR0cHM6Ly9naXRodWIuY29tL01ldGFDdWJlWC9tZXRhLXJ1bGVzLWRhdC9yZWxlYXNlcy9sYXRlc3QvZG93bmxvYWQvZ2VvaXAuZGF0"

wget -q -O /opt/clash/geosite.dat $(echo "$ENC_GEOSITE" | base64 -d)
wget -q -O /opt/clash/geoip.dat $(echo "$ENC_GEOIP" | base64 -d)

print_msg "Geo databases installed"

print_step "Setting up Geo database auto-update"

crontab -l 2>/dev/null | grep -v meta-rules-dat > /tmp/cron_clash

echo "0 4 1 * * wget -q -O /opt/clash/geosite.dat \$(echo \"$ENC_GEOSITE\" | base64 -d)" >> /tmp/cron_clash
echo "0 4 1 * * wget -q -O /opt/clash/geoip.dat \$(echo \"$ENC_GEOIP\" | base64 -d)" >> /tmp/cron_clash

crontab /tmp/cron_clash
rm -f /tmp/cron_clash

/etc/init.d/cron enable
/etc/init.d/cron restart

print_msg "Cron job installed"

print_step "Rebooting device"

sleep 2
reboot
